# Docker Compose 环境变量（复制为 .env 后修改）
# 本地开发和 Docker 部署共用同一个 .env 文件

# ── 基础设施密码（必须替换） ──────────────────────
POSTGRES_PASSWORD=replace-with-strong-password
MINIO_ACCESS_KEY=replace-with-strong-key
MINIO_SECRET_KEY=replace-with-strong-secret

# ── 应用层配置 ────────────────────────────────────
# LLM（必填）
LLM_API_KEY=your_api_key_here
LLM_MODEL=openai/kimi-k2.5
LLM_BASE_URL=https://api.moonshot.cn/v1

# 数据库（Docker 内部通信，无需修改）
DATABASE_URL=postgresql+psycopg2://postgres:replace-with-strong-password@postgres:5432/mini_agent

# Milvus（Docker 内部通信，无需修改）
MILVUS_URI=http://standalone:19530

# JWT（必须替换为随机字符串）
JWT_SECRET_KEY=generate-a-random-secret

# Embedding
EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2
RETRIEVAL_STRATEGY=bm25_primary

# LangSmith（可选）
# LANGCHAIN_TRACING_V2=true
# LANGCHAIN_API_KEY=your_langsmith_key_here
# LANGCHAIN_PROJECT=mini-agent
